# Copy to .env before running docker compose.

# Published ports
PLAYGROUND_HOST_PORT=7878
PROXY_HTTP_PORT=8080

# Hosted-mode security controls passed through to tarsier-playground
TARSIER_AUTH_TOKEN=
TARSIER_ALLOWED_ORIGINS=
TARSIER_MAX_DEPTH=12
TARSIER_MAX_TIMEOUT_SECS=60
TARSIER_MAX_CONCURRENT_SOLVERS=4
TARSIER_RATE_LIMIT_PER_MIN=30
TARSIER_MAX_REQUEST_BYTES=524288
TARSIER_MAX_SOURCE_BYTES=262144
TARSIER_MAX_RESPONSE_BYTES=8388608
