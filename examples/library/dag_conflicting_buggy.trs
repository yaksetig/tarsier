// DAG round bug: conflicting decisions with weak guards.
// Despite DAG round structure, processes can decide true or false
// with only 1 message threshold, allowing disagreement.
protocol DagBuggyConflicting {
    params n, t, f;
    resilience: n > 3*t;
    adversary { model: byzantine; bound: f; }

    dag_round r0;
    dag_round r1 extends r0;

    message Vote;
    message Reject;

    role Node {
        var decided: bool = false;
        var decision: bool = false;
        init propose;
        phase propose {
            when received >= 1 Vote => {
                decision = true;
                decided = true;
                decide true;
                goto phase done_yes;
            }
            when received >= 1 Reject => {
                decision = false;
                decided = true;
                decide false;
                goto phase done_no;
            }
        }
        phase done_yes {}
        phase done_no {}
    }
    property agreement: agreement {
        forall p: Node. forall q: Node.
            (p.decided == true && q.decided == true) ==> (p.decision == q.decision)
    }
}
