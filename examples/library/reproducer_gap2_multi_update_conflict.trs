// RECONF-01 GAP-2 reproducer: multiple rules updating the same parameter.
//
// Two rules in the same phase both reconfigure t to different values.
// Both can fire in the same BMC step, generating contradictory SMT constraints:
//   delta_r1 > 0 → p_t_{k+1} = 1
//   delta_r2 > 0 → p_t_{k+1} = 2
// When both deltas are positive, the formula becomes unsatisfiable, making
// the BMC report false-SAFE (the bad state is unreachable because no step
// can execute at all).
//
// Expected verdict after RECONF-02 fix: UNSAFE (trivial disagreement, clean encoding).
// Current verdict: UNSAFE at depth 3 (BMC finds a path where only one rule fires),
// but the encoding is unsound — conflicting constraints at steps where both rules
// fire make those steps unsatisfiable, potentially masking deeper bugs.

protocol MultiUpdateConflictReproducer {
    params n, t, f;
    resilience: n > 3*t;
    adversary { model: byzantine; bound: f; }

    message Vote;
    message Reject;

    role Process {
        var decided: bool = false;
        var decision: bool = false;
        init waiting;

        phase waiting {
            when received >= 1 Vote => {
                reconfigure { t = 1; }
                decision = true;
                decided = true;
                decide true;
                goto phase done_yes;
            }
            when received >= 1 Reject => {
                reconfigure { t = 2; }
                decision = false;
                decided = true;
                decide false;
                goto phase done_no;
            }
        }

        phase done_yes {}
        phase done_no {}
    }

    property agreement: agreement {
        forall p: Process. forall q: Process.
            (p.decided == true && q.decided == true) ==> (p.decision == q.decision)
    }
}
