// Bounded-log unsafe counterpart: weak guards can finalize conflicting values.
// The bounded log is still exercised via append operations on both branches.
protocol BoundedLogOverflowBuggy {
    params n, t, f;
    resilience: n > 3*t;

    adversary {
        model: byzantine;
        bound: f;
    }

    log VoteHistory: int[2];
    message VoteYes;
    message VoteNo;

    role Voter {
        var decided: bool = false;
        var decision: bool = false;
        init waiting;

        phase waiting {
            when received >= 1 VoteYes => {
                append VoteHistory 1;
                decision = true;
                decided = true;
                decide true;
                goto phase done_yes;
            }
            when received >= 1 VoteNo => {
                append VoteHistory 0;
                decision = false;
                decided = true;
                decide false;
                goto phase done_no;
            }
        }

        phase done_yes {}
        phase done_no {}
    }

    property agreement: agreement {
        forall p: Voter. forall q: Voter.
            (p.decided == true && q.decided == true) ==> (p.decision == q.decision)
    }
}
