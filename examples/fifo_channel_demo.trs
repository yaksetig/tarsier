// Demonstrates FIFO channel type with enqueue/dequeue semantics.
// FIFO channels model bounded queues with head/tail index tracking.

protocol FifoChannelDemo {

params n, t, f;
resilience: n > 3*t;
adversary { model: byzantine; bound: f; }

fifo_channel RequestQueue: int[n];

message Request;

role Worker {
    init Waiting;
    phase Waiting {
        when received >= 1 Request => {
            enqueue RequestQueue 1;
            goto phase Waiting;
        }
    }
    phase Processing {
        when received >= 1 Request => {
            dequeue RequestQueue;
            goto phase Processing;
        }
    }
}

property safe: safety {
    forall p: Worker. forall q: Worker.
        p.Waiting == 0 || q.Waiting == 0
}

}
