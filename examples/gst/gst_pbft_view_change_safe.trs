protocol GstPbftViewChangeSafe {
    params n, t, f, gst;
    resilience: n > 3*t;

    adversary {
        model: byzantine;
        bound: f;
        values: sign;
        auth: signed;
        network: process_selective;
        delivery: per_recipient;
        faults: per_recipient;
        equivocation: none;
    }

    timing {
        model: partial_synchrony;
        gst: gst;
    }

    identity Replica: process(pid) key replica_key;

    message ViewChange(view: nat in 0..3);
    message NewView(view: nat in 0..3);

    role Replica {
        // Safe anchor: already decided so liveness is trivially satisfied post-GST.
        var pid: nat in 0..3;
        var decided: bool = true;
        init pre;

        phase pre {
            when received >= 2*t+1 NewView(view=0) => {
                decided = true;
                goto phase decided;
            }
        }

        phase decided {}
    }

    property agreement: agreement {
        forall p: Replica. forall q: Replica.
            p.decided == q.decided
    }

    property termination: liveness {
        forall p: Replica. p.decided == true
    }
}
