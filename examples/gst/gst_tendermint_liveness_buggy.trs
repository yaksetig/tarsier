protocol GstTendermintLivenessBuggy {
    params n, t, f, gst;
    resilience: n > 3*t;

    adversary {
        model: byzantine;
        bound: f;
        values: sign;
        auth: signed;
        network: process_selective;
        delivery: per_recipient;
        faults: per_recipient;
        equivocation: none;
    }

    timing {
        model: partial_synchrony;
        gst: gst;
    }

    identity Validator: process(pid) key validator_key;

    message Proposal(round: nat in 0..3, value: nat in 0..3);
    message Prevote(round: nat in 0..3, value: nat in 0..3);
    message Precommit(round: nat in 0..3, value: nat in 0..3);

    role Validator {
        // Buggy variant: decision cannot be reached in this model.
        var pid: nat in 0..3;
        var decided: bool = false;
        init propose;

        phase propose {
            when received >= n+1 Precommit(round=0, value=0) => {
                decided = true;
                goto phase decided;
            }
        }

        phase decided {}
    }

    property agreement: agreement {
        forall p: Validator. forall q: Validator.
            p.decided == q.decided
    }

    property termination: liveness {
        forall p: Validator. p.decided == true
    }
}
