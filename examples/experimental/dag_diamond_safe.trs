// DAG diamond pattern: r0 → r1, r0 → r2, r1,r2 → r3.
// Safe: single decision path with strong guards.
protocol DagDiamondSafe {
    params n, t, f;
    resilience: n > 3*t;
    adversary { model: byzantine; bound: f; }

    dag_round r0;
    dag_round r1 extends r0;
    dag_round r2 extends r0;
    dag_round r3 extends r1, r2;

    message Vote;

    role Node {
        var decided: bool = false;
        init propose;

        phase propose {
            when received >= n - t Vote => {
                goto phase done;
            }
        }
        phase done {}
    }

    property inv: invariant {
        forall p: Node. p.decided == false
    }
}
