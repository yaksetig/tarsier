protocol DagRoundAlphaSafe {
    params n, t, f;
    resilience: n > 3*t;
    adversary { model: byzantine; bound: f; }

    dag_round r0;
    dag_round r1 extends r0;
    dag_round r2 extends r0, r1;

    role Node {
        var decided: bool = false;
        init propose;

        phase propose {}

        phase done {}
    }

    property inv: invariant {
        forall p: Node. p.decided == false
    }
}
